ELASTIC_VERSION=8.13.0

# Destination cluster (your existing ES/Kibana)
DESTINATION_ES_HOST=https://your-destination-cluster:9200
DESTINATION_ES_USER=elastic
DESTINATION_ES_PASSWORD=changeme
KIBANA_HOST=https://your-kibana:5601

# Source cluster (the cluster being monitored)
SOURCE_ES_HOST=https://your-source-cluster:9200
SOURCE_ES_USER=elastic
SOURCE_ES_PASSWORD=changeme
ES_SSL_VERIFY=full

# Organization metadata injected into every Metricbeat event
ORGANIZATION_ID=org_001
ORGANIZATION_NAME=Client Name
